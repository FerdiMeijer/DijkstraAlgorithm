{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug ConsoleApp",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/DijkstraAlgorithm.ConsoleApp/bin/Debug/net10.0/DijkstraAlgorithm.ConsoleApp.dll",
            "cwd": "${workspaceFolder}/DijkstraAlgorithm.ConsoleApp/bin/Debug/net10.0/",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Attach to Process",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
